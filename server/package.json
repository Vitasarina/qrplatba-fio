{
  "name": "qr-payments-server",
  "version": "0.1.0",
  "description": "Runnable Node/TypeScript reference backend for the QR Platba (SPAYD) payments MVP — simulator phase.",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "build:web": "cd ../web && npm run build",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "build:exe": "npm run build:web && node scripts/build-exe.mjs"
  },
  "dependencies": {
    "decimal.js": "^10.4.3",
    "fastify": "^4.28.1",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@types/node": "^22.5.0",
    "@types/qrcode": "^1.5.5",
    "esbuild": "^0.28.1",
    "pkg": "^5.8.1",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4",
    "vitest": "^2.0.5"
  }
}
